# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — get this from resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Admin email — where pledge notifications get sent
ADMIN_EMAIL=abdatorey@gmail.com

# Admin dashboard password — choose something strong
ADMIN_PASSWORD=your-strong-password-here

# Your live site URL (used in email links) — set this on Vercel too
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
